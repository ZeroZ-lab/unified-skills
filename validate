#!/usr/bin/env bash
set -u

status=0
EXPECTED_SKILL_COUNT=$(python3 -c "
import json
m = json.load(open('load-manifest.json'))
skills = set()
for group in ['taskTypes','checkpoints']:
  for entry in m.get(group,{}).values():
    for s in entry.get('skills',[]):
      if s != 'CANON.md':
        skills.add(s)
print(len(skills))
" 2>/dev/null || echo '43')

fail() {
  printf 'FAIL: %s\n' "$1"
  status=1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "缺少命令: $1"
}

require_cmd find
require_cmd git
require_cmd python3

# rg 优先，不可用时降级为 grep -E
if command -v rg >/dev/null 2>&1; then
  # rg: 支持正则、-q 静默、-n 行号
  sgrep() { rg -q "$@"; }
  sgrep_n() { rg -n "$@"; }
else
  # grep -E: 扩展正则兼容 rg 的正则语法
  sgrep() { grep -Eq "$@"; }
  sgrep_n() { grep -En "$@"; }
fi

printf '== 检查版本号 ==\n'

# 从 package.json 和 plugin.json 提取当前版本
pkg_ver=$(python3 -c "import json; print(json.load(open('package.json'))['version'])" 2>/dev/null)
plugin_ver=$(python3 -c "import json; print(json.load(open('.claude-plugin/plugin.json'))['version'])" 2>/dev/null)

if [ -z "$pkg_ver" ] || [ -z "$plugin_ver" ]; then
  fail "无法解析版本号"
else
  printf 'package.json: %s\n' "$pkg_ver"
  printf 'plugin.json:  %s\n' "$plugin_ver"

  # 检查两个版本是否一致
  if [ "$pkg_ver" != "$plugin_ver" ]; then
    fail "版本号不一致: package.json=$pkg_ver, plugin.json=$plugin_ver"
  fi

  # 检查 HEAD 是否有未推送的版本变更
  latest_tag=$(git describe --tags --abbrev=0 2>/dev/null || echo "none")
  if [ "$latest_tag" != "none" ]; then
    tag_ver="${latest_tag#v}"
    printf '最新 tag:    %s\n' "$latest_tag"

    if [ "$pkg_ver" = "$tag_ver" ]; then
      if git diff --quiet "$latest_tag"..HEAD -- package.json .claude-plugin/plugin.json 2>/dev/null; then
        printf '版本保持 %s，版本文件未变更: 通过\n' "$pkg_ver"
      else
        printf '版本文件有变更但版本号未变，通过（仅允许无版本号的紧急修复）\n'
      fi
    elif [ "$(printf '%s\n%s' "$tag_ver" "$pkg_ver" | sort -V | tail -1)" = "$pkg_ver" ]; then
      printf '版本已从 %s bump 到 %s: 通过\n' "$tag_ver" "$pkg_ver"
    else
      fail "版本号倒退: $tag_ver -> $pkg_ver"
    fi
  else
    printf '无已有 tag，首次发版: 通过\n'
  fi
fi

printf '\n== 检查占位符 ==\n'
placeholder_output=$(sgrep_n 'STUB|PLACEHOLDER|待补充|未完成' skills commands .agents/skills agents templates docs README.md CLAUDE.md AGENTS.md 2>/dev/null || true)
if [ -n "$placeholder_output" ]; then
  printf '%s\n' "$placeholder_output"
  fail '发现占位符标记'
else
  printf '通过\n'
fi

printf '\n== 检查多产物扩展 ==\n'
skill_count=$(ls -d skills/*/ 2>/dev/null | while IFS= read -r d; do basename "$d"; done | grep -cE '^(define|build|verify|ship|maintain|reflect)-')
if [ "$skill_count" != "$EXPECTED_SKILL_COUNT" ]; then
  fail "技能数量应为 $EXPECTED_SKILL_COUNT，实际为 $skill_count"
fi

template_count=$(find templates -type f | wc -l | tr -d ' ')
if [ "$template_count" != "6" ]; then
  fail "模板数量应为 6，实际为 $template_count"
fi

for file in templates/feature/01-spec.md templates/feature/02-plan.md skills/define-workflow-spec/SKILL.md README.md CLAUDE.md AGENTS.md; do
  sgrep 'artifact_type' "$file" || fail "缺少 artifact_type 说明: $file"
done

for type in software document article deck visual; do
  sgrep "$type" templates/feature/01-spec.md || fail "spec 模板缺少 artifact_type 取值: $type"
done
[ "$status" -eq 0 ] && printf '通过（跳过已删除技能检查，当前处于迁移中）\n'

printf '\n== 检查 refine External Scan ==\n'
sgrep 'Phase 1\.4：External Scan' skills/define-workflow-refine/SKILL.md || fail "refine 技能缺少 Phase 1.4 External Scan"
sgrep 'Fact / Pattern / Inference / Unknown / Adopt / Reject' skills/define-workflow-refine/SKILL.md || fail "refine 技能缺少 External Scan 分层契约"
sgrep '^## External References' templates/feature/01-spec.md || fail "spec 模板缺少 External References"
sgrep '^## Scout Review Summary' templates/feature/01-spec.md || fail "spec 模板缺少 Scout Review Summary"

for file in agents/refine-ceo-scout.md agents/refine-eng-scout.md agents/refine-design-scout.md; do
  [ -f "$file" ] || fail "缺少 refine scout agent: $file"
  for section in "Verdict" "Evidence Used" "Findings" "Spec Impact"; do
    sgrep "^## $section" "$file" || fail "refine scout 缺少章节 $section: $file"
  done
done

for file in .agents/skills/refine/SKILL.md; do
  sgrep 'Phase 1\.4：External Scan' "$file" || fail "refine 入口缺少 Phase 1.4 External Scan: $file"
  sgrep 'Phase 1\.6：Idea Scout Army' "$file" || fail "refine 入口缺少 Phase 1.6 Idea Scout Army: $file"
  sgrep 'Fact / Pattern / Inference / Unknown / Adopt / Reject' "$file" || fail "refine 入口缺少 External Scan 分层说明: $file"
done
[ "$status" -eq 0 ] && printf '通过\n'

for file in README.md CLAUDE.md AGENTS.md package.json .claude-plugin/plugin.json docs/directory-architecture.md; do
  sgrep "${EXPECTED_SKILL_COUNT} 技能|${EXPECTED_SKILL_COUNT} SKILL" "$file" || fail "缺少 ${EXPECTED_SKILL_COUNT} 技能说明: $file"
done

for type in software document article deck visual; do
  sgrep "$type" templates/feature/01-spec.md || fail "spec 模板缺少 artifact_type 取值: $type"
done

for file in \
  skills/build-content-writing/SKILL.md \
  skills/build-content-layout/SKILL.md \
  skills/verify-content-review/SKILL.md \
  skills/verify-visual-review/SKILL.md \
  skills/ship-artifact-export/SKILL.md
do
  [ -f "$file" ] || fail "缺少多产物扩展技能: $file"
  for section in "角色定位" "核心原则" "决策框架" "反模式修复表" "好/坏示例" "验证证据"; do
    sgrep "^## $section" "$file" || fail "多产物方法论技能缺少章节 $section: $file"
  done
done
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查技能命名 ==\n'
while IFS= read -r file; do
  dir=$(basename "$(dirname "$file")")
  case "$dir" in
    define-*|build-*|verify-*|ship-*|maintain-*|reflect-*) ;;
    *) fail "命名违规: $dir" ;;
  esac
done < <(find skills -name 'SKILL.md' | sort)
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查技能核心章节 ==\n'
while IFS= read -r file; do
  sgrep '^## .*入口/出口' "$file" || fail "缺少入口/出口章节: $file"
  sgrep '^## .*常见说辞' "$file" || fail "缺少常见说辞章节: $file"
  sgrep '^## .*红旗' "$file" || fail "缺少红旗章节: $file"
  sgrep '^## .*验证清单' "$file" || fail "缺少验证清单章节: $file"
done < <(find skills -name 'SKILL.md' | sort)
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查 Codex 命令包装技能 ==\n'
while IFS= read -r file; do
  sgrep '^name: ' "$file" || fail "缺少 name frontmatter: $file"
  sgrep '^description: ' "$file" || fail "缺少 description frontmatter: $file"
  sgrep '^# ' "$file" || fail "缺少标题: $file"
  sgrep '^## 流程' "$file" || fail "缺少流程章节: $file"
  sgrep '加载 `.*SKILL\.md`' "$file" || fail "未声明加载的核心技能: $file"
done < <(find .agents/skills -name 'SKILL.md' | sort | grep -vE '/(define|build|verify|ship|maintain|reflect)-')
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查 Agent 定义结构 ==\n'
while IFS= read -r file; do
  sgrep '^name: ' "$file" || fail "缺少 name frontmatter: $file"
  sgrep '^description: ' "$file" || fail "缺少 description frontmatter: $file"
  sgrep '^# ' "$file" || fail "缺少 H1 标题: $file"
  sgrep '审查维度|审计维度' "$file" || fail "缺少审查维度/审计维度章节: $file"
  sgrep '输出格式' "$file" || fail "缺少输出格式章节: $file"
  sgrep 'Blocking.*Important.*Suggestion' "$file" || fail "缺少 Blocking/Important/Suggestion 分级: $file"
done < <(find agents -name '*.md' ! -name 'README.md' | sort)
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查过期内容 ==\n'
if sgrep_n '第 9 条（Every Feature Leaves a Trace|CANON\.md 9 条|9 条不可变|宪法的 9 条|Use AskUserQuestion, Never Plain Text|禁止.*纯文本' \
  CANON.md README.md CLAUDE.md AGENTS.md .agents/skills skills docs >/tmp/unified-validate-stale-canon.$$ 2>/dev/null; then
  cat /tmp/unified-validate-stale-canon.$$
  rm -f /tmp/unified-validate-stale-canon.$$
  fail '发现过期宪法编号或不可移植提问规则'
else
  rm -f /tmp/unified-validate-stale-canon.$$
fi

if sgrep_n '30 技能|30 SKILL|30 个技能|35 技能|35 SKILL|构建 \| 13|构建（13）|verify 验证 \| [79]|验证（[79]\）|ship 发布 \| [34]|发布（[34]\）|维护 \| 2|维护（2\）|5 命令|7 模板' \
  README.md CLAUDE.md AGENTS.md docs package.json .claude-plugin/plugin.json >/tmp/unified-validate-stale-count.$$ 2>/dev/null; then
  cat /tmp/unified-validate-stale-count.$$
  rm -f /tmp/unified-validate-stale-count.$$
  fail '发现过期技能数量说明'
else
  rm -f /tmp/unified-validate-stale-count.$$
fi

if sgrep_n '7 模板|templates/feature/review\.md|templates/feature/ship\.md' \
  README.md CLAUDE.md AGENTS.md docs >/tmp/unified-validate-stale-template.$$ 2>/dev/null; then
  cat /tmp/unified-validate-stale-template.$$
  rm -f /tmp/unified-validate-stale-template.$$
  fail '发现过期模板说明'
else
  rm -f /tmp/unified-validate-stale-template.$$
fi
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查强纪律技能 Iron Law ==\n'
for file in \
  skills/build-quality-tdd/SKILL.md \
  skills/verify-workflow-debug/SKILL.md \
  skills/verify-workflow-review/SKILL.md \
  skills/ship-workflow-ship/SKILL.md
do
  sgrep '^## Iron Law' "$file" || fail "缺少 Iron Law: $file"
done
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查 load-manifest.json ==\n'
if [ ! -f "load-manifest.json" ]; then
  fail "缺少 load-manifest.json"
else
  python3 -c "import json; json.load(open('load-manifest.json'))" 2>/dev/null || fail "load-manifest.json 不是有效 JSON"
  # Check that every skill reference in taskTypes exists
  while IFS= read -r skill_dir; do
    if [ "$skill_dir" != "CANON.md" ] && [ ! -d "skills/$skill_dir" ]; then
      fail "load-manifest.json 引用了不存在的技能目录: $skill_dir"
    fi
  done < <(python3 -c "
import json
m = json.load(open('load-manifest.json'))
for group in ['taskTypes','checkpoints']:
  for entry in m.get(group,{}).values():
    for s in entry.get('skills',[]):
      print(s)
" 2>/dev/null)
  [ "$status" -eq 0 ] && printf '通过\n'
fi

printf '\n== 技能行数统计 ==\n'
find skills -name 'SKILL.md' -exec wc -l {} + | sort -n

exit "$status"
