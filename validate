#!/usr/bin/env bash
set -u

STRICT=0
if [ "${1:-}" = "--strict" ]; then
  STRICT=1
fi

status=0

fail() {
  printf 'FAIL: %s\n' "$1"
  status=1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "缺少命令: $1"
}

require_cmd find
require_cmd git
require_cmd python3

# rg 优先，不可用时降级为 grep -E
if command -v rg >/dev/null 2>&1; then
  sgrep() { rg -q "$@"; }
else
  sgrep() { grep -Eq "$@"; }
fi

# ──────────────────────────────────────────
# Tier 1: 运行时正确性检查
# ──────────────────────────────────────────

## 1. 版本一致性
printf '\n== 检查版本号 ==\n'
pkg_ver=$(python3 -c "import json; print(json.load(open('package.json'))['version'])" 2>/dev/null)
plugin_ver=$(python3 -c "import json; print(json.load(open('.claude-plugin/plugin.json'))['version'])" 2>/dev/null)
codex_plugin_ver=$(python3 -c "import json; print(json.load(open('.codex-plugin/plugin.json'))['version'])" 2>/dev/null)

if [ -z "$pkg_ver" ] || [ -z "$plugin_ver" ] || [ -z "$codex_plugin_ver" ]; then
  fail "无法解析版本号"
else
  printf 'package.json:         %s\n' "$pkg_ver"
  printf '.claude-plugin:       %s\n' "$plugin_ver"
  printf '.codex-plugin:        %s\n' "$codex_plugin_ver"
  if [ "$pkg_ver" != "$plugin_ver" ]; then
    fail "版本号不一致: package.json=$pkg_ver, .claude-plugin/plugin.json=$plugin_ver"
  fi
  if [ "$pkg_ver" != "$codex_plugin_ver" ]; then
    fail "版本号不一致: package.json=$pkg_ver, .codex-plugin/plugin.json=$codex_plugin_ver"
  fi
  latest_tag=$(git describe --tags --abbrev=0 2>/dev/null || echo "none")
  if [ "$latest_tag" != "none" ]; then
    tag_ver="${latest_tag#v}"
    printf '最新 tag:             %s\n' "$latest_tag"
    if [ "$pkg_ver" = "$tag_ver" ]; then
      if git diff --quiet "$latest_tag"..HEAD -- package.json .claude-plugin/plugin.json .codex-plugin/plugin.json 2>/dev/null; then
        printf '版本保持 %s，版本文件未变更: 通过\n' "$pkg_ver"
      else
        printf '版本文件有变更但版本号未变，通过\n'
      fi
    elif [ "$(printf '%s\n%s' "$tag_ver" "$pkg_ver" | sort -V | tail -1)" = "$pkg_ver" ]; then
      printf '版本已从 %s bump 到 %s: 通过\n' "$tag_ver" "$pkg_ver"
    else
      fail "版本号倒退: $tag_ver -> $pkg_ver"
    fi
  else
    printf '无已有 tag，首次发版: 通过\n'
  fi
fi

## 2. 插件元数据描述
printf '\n== 检查插件元数据描述 ==\n'
python3 scripts/check-version.py "$pkg_ver" || fail "插件元数据描述与版本/动态数量规则不一致"
[ "$status" -eq 0 ] && printf '通过\n'

## 3. 占位符检测
printf '\n== 检查占位符 ==\n'
placeholder_output=$(rg -n 'STUB|PLACEHOLDER|待补充|尚未实现' skills commands agents templates docs references README.md CLAUDE.md AGENTS.md 2>/dev/null || true)
if [ -n "$placeholder_output" ]; then
  printf '%s\n' "$placeholder_output"
  fail '发现占位符标记'
else
  printf '通过\n'
fi

## 4. 技能计数 vs 索引
printf '\n== 检查多产物扩展 ==\n'
EXPECTED_SKILL_COUNT=$(python3 -c "
import json
idx = json.load(open('skills-index.json'))
skills = set()
for phase_skills in idx['by_phase'].values():
    skills.update(phase_skills['skills'])
print(len(skills))
" 2>/dev/null) || EXPECTED_SKILL_COUNT=0
skill_count=$(ls -d skills/*/ 2>/dev/null | while IFS= read -r d; do basename "$d"; done | grep -cE '^(define|design|build|verify|ship|maintain|reflect)-')
if [ "$skill_count" != "$EXPECTED_SKILL_COUNT" ]; then
  fail "技能数量应为 $EXPECTED_SKILL_COUNT，实际为 $skill_count"
fi
for file in \
  templates/feature/00-brainstorm.md \
  templates/feature/01-spec.md \
  templates/feature/02-design.md \
  templates/feature/03-plan.md \
  templates/feature/04-review.md \
  templates/feature/05-ship.md \
  templates/feature/06-canary-report.md \
  templates/feature/07-deploy-report.md \
  skills/define-workflow-spec/SKILL.md \
  README.md AGENTS.md
do
  sgrep 'artifact_type' "$file" || fail "缺少 artifact_type 说明: $file"
done
for type in software document article deck visual; do
  sgrep "$type" templates/feature/01-spec.md || fail "spec 模板缺少 artifact_type 取值: $type"
done
[ "$status" -eq 0 ] && printf '通过\n'

## 5. 技能命名规范
printf '\n== 检查技能命名 ==\n'
while IFS= read -r file; do
  dir=$(basename "$(dirname "$file")")
  case "$dir" in
    define-*|design-*|build-*|verify-*|ship-*|maintain-*|reflect-*) ;;
    *) fail "命名违规: $dir" ;;
  esac
done < <(find skills -name 'SKILL.md' | sort)
[ "$status" -eq 0 ] && printf '通过\n'

## 6. CLAUDE 指针文件
printf '\n== 检查 CLAUDE 指针文件 ==\n'
sgrep 'AGENTS\.md' CLAUDE.md || fail "CLAUDE.md 必须指向 AGENTS.md"
[ "$status" -eq 0 ] && printf '通过\n'

## 7. skills-index.json 一致性
printf '\n== 检查 skills-index.json ==\n'
python3 scripts/check-skills-index.py || fail "skills-index.json 与真实技能集不一致"
[ "$status" -eq 0 ] && printf '通过\n'

## 8. skills-lock.json 哈希
printf '\n== 检查 skills-lock.json 完整性 ==\n'
python3 scripts/check-skills-lock.py || fail "skills-lock.json 完整性检查失败"
[ "$status" -eq 0 ] && printf '通过\n'

## 9. hooks.json schema
printf '\n== 检查 hooks.json ==\n'
python3 scripts/check-hooks-schema.py || fail "hooks/hooks.json schema 无效"
[ "$status" -eq 0 ] && printf '通过\n'

## 10. Claude Code skill-load monitors
printf '\n== 检查 Claude Code skill-load monitors ==\n'
python3 scripts/check-monitors.py || fail "Claude Code skill-load monitors 配置无效"
[ "$status" -eq 0 ] && printf '通过\n'

## 11. Context Runtime / Router
printf '\n== 检查 Context Runtime 合同 ==\n'
python3 scripts/check-router.py || fail "Context Runtime 合同不一致"
[ "$status" -eq 0 ] && printf '通过\n'

## 12. Unified feature state
printf '\n== 检查 Unified feature state ==\n'
python3 scripts/check-feature-state.py || fail "Unified feature state 合同不一致"
[ "$status" -eq 0 ] && printf '通过\n'

## 13. Pipeline 序列 + 路由
printf '\n== 检查 pipeline 路由与序列 ==\n'
python3 scripts/check-pipelines.py || fail "pipeline 路由或序列不正确"
[ "$status" -eq 0 ] && printf '通过\n'

## 14. 技能加载合同
printf '\n== 检查技能加载合同 ==\n'
python3 scripts/check-skill-load-contracts.py || fail "技能加载合同不一致"
[ "$status" -eq 0 ] && printf '通过\n'

## 15. Codex 平台
printf '\n== 检查 Codex plugin manifest ==\n'
python3 scripts/check-codex-platform.py || fail "Codex 平台检查失败"
[ "$status" -eq 0 ] && printf '通过\n'

## 16. 自动化脚本存在 + 可执行
printf '\n== 检查自动化脚本 ==\n'
for script in scripts/sync-version.sh scripts/generate-index.sh scripts/notify-skill-loaded.sh scripts/generate-skill-load-monitors.sh; do
  [ -f "$script" ] || fail "缺少脚本: $script"
  [ -x "$script" ] || fail "脚本不可执行: chmod +x $script"
done
for script in scripts/check-agent-contracts.py scripts/check-doc-sync-contract.py; do
  [ -f "$script" ] || fail "缺少脚本: $script"
done
[ -d "scripts/tests" ] || fail "缺少脚本测试目录: scripts/tests"
for test in test-sync-version.sh test-generate-index.sh test-hooks.sh test-agent-contracts.sh test-unified-state.sh; do
  [ -f "scripts/tests/$test" ] || fail "缺少测试: scripts/tests/$test"
done
[ "$status" -eq 0 ] && printf '通过\n'

## 17. Agent 合同负向测试
printf '\n== 检查 Agent 合同负向测试 ==\n'
bash scripts/tests/test-agent-contracts.sh || fail "Agent 合同负向测试失败"
[ "$status" -eq 0 ] && printf '通过\n'

## 18. Hook 行为测试
printf '\n== 检查 hook 行为 ==\n'
bash scripts/tests/test-hooks.sh || fail "hook 行为测试失败"

## 19. 技能行数统计
printf '\n== 技能行数统计 ==\n'
find skills -name 'SKILL.md' | sort | while IFS= read -r f; do
  printf '%6d %s\n' "$(wc -l < "$f")" "$f"
done
echo "---"
total=$(find skills -name 'SKILL.md' -exec cat {} + | wc -l | tr -d ' ')
echo "$total total"

# ──────────────────────────────────────────
# Tier 2: 结构约定检查（--strict）
# ──────────────────────────────────────────

if [ "$STRICT" -eq 1 ]; then
  printf '\n══════════════════════════════════════════\n'
  printf '  --strict: 结构约定检查\n'
  printf '══════════════════════════════════════════\n'
  python3 scripts/check-strict.py || fail "结构约定检查失败"
fi

# ──────────────────────────────────────────
# 退出
# ──────────────────────────────────────────

if [ "$status" -ne 0 ]; then
  printf '\n存在 FAIL，请修复后再提交。\n'
  exit 1
fi

printf '\n全部通过。\n'
exit 0
