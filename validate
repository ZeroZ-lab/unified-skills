sgrep 'Sources / Patterns / Inferences / Adopt / Reject / Unknown' commands/design.md || fail "/design 缺少 scan 输出契约"
sgrep 'Design References' commands/design.md || fail "/design 缺少 Design References gate"

for pattern in \
  '^## Design References' \
  '^## Pattern Synthesis' \
  '^## Design Inferences' \
  '^## Adopt / Reject' \
  '^## Design Evidence Quality'
do
  sgrep "$pattern" templates/feature/02-design.md || fail "02-design 模板缺少 $pattern"
done

sgrep '设计证据质量' agents/design-reviewer.md || fail "design-reviewer 缺少设计证据质量审查"
sgrep '缺少 Design References' agents/design-reviewer.md || fail "design-reviewer 缺少 Design References blocking"
sgrep '缺少 Design Inferences' agents/design-reviewer.md || fail "design-reviewer 缺少 Design Inferences blocking"
sgrep '缺少 Adopt / Reject' agents/design-reviewer.md || fail "design-reviewer 缺少 Adopt / Reject blocking"

python3 - <<'PY' || fail "非 software 用户可见产物未强制加载 design-workflow-design"
import json
idx = json.load(open("skills-index.json"))
for artifact in ("document", "article", "deck", "visual"):
    required = idx["by_artifact_type"][artifact]["required"]
    if "design-workflow-design" not in required:
        raise SystemExit(f"{artifact}.required missing design-workflow-design")
