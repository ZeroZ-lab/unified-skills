sgrep 'colors:' templates/root/DESIGN.md || fail "DESIGN.md 模板缺少 YAML colors token"
sgrep 'typography:' templates/root/DESIGN.md || fail "DESIGN.md 模板缺少 YAML typography token"
sgrep 'components:' templates/root/DESIGN.md || fail "DESIGN.md 模板缺少 YAML components token"
sgrep 'Sync Log' templates/root/DESIGN.md || fail "DESIGN.md 模板缺少 Sync Log 章节"
sgrep 'DESIGN\.md' skills/design-workflow-design/SKILL.md || fail "design-workflow-design 缺少 DESIGN.md 引用"
sgrep 'DESIGN\.md' commands/design.md || fail "design 命令缺少 DESIGN.md 引用"
sgrep 'DESIGN\.md' references/design-best-practices.md || fail "design-best-practices 缺少 DESIGN.md 说明"
sgrep 'design-inspiration-catalog' skills/design-workflow-design/SKILL.md || fail "design-workflow-design 缺少 design-inspiration-catalog 引用"
sgrep 'design-pattern-extract' skills/design-workflow-design/SKILL.md || fail "design-workflow-design 缺少 design-pattern-extract 引用"
sgrep 'Step 3\.5：Codex' skills/design-workflow-design/SKILL.md || fail "design-workflow-design 缺少 Step 3.5 Codex 视觉生成"
sgrep 'design-tokens-extracted' skills/design-workflow-design/SKILL.md || fail "design-workflow-design 缺少 design-tokens-extracted 产物"
sgrep 'Phase 2\.5: Codex' commands/design.md || fail "design 命令缺少 Phase 2.5 Codex 视觉生成"
sgrep 'mockup-direction' commands/design.md || fail "design 命令缺少 mockup 产物说明"
sgrep 'codex-rescue' AGENTS.md || fail "AGENTS 缺少 codex-rescue 引用"
sgrep 'design-tokens-extracted' AGENTS.md || fail "AGENTS 缺少 design-tokens-extracted 产物说明"
[ -f "references/design-inspiration-catalog.md" ] || fail "缺少设计灵感目录: references/design-inspiration-catalog.md"
[ -f "references/design-pattern-extract.md" ] || fail "缺少设计模式提取: references/design-pattern-extract.md"
[ "$status" -eq 0 ] && printf '通过\n'

for file in README.md AGENTS.md package.json .claude-plugin/plugin.json docs/directory-architecture.md; do
  sgrep "${EXPECTED_SKILL_COUNT} 技能|${EXPECTED_SKILL_COUNT} SKILL" "$file" || fail "缺少 ${EXPECTED_SKILL_COUNT} 技能说明: $file"
done

for type in software document article deck visual; do
  sgrep "$type" templates/feature/01-spec.md || fail "spec 模板缺少 artifact_type 取值: $type"
done

for file in \
  skills/build-content-writing/SKILL.md \
  skills/build-content-layout/SKILL.md \
  skills/verify-content-review/SKILL.md \
  skills/verify-visual-review/SKILL.md \
  skills/ship-artifact-export/SKILL.md
do
  [ -f "$file" ] || fail "缺少多产物扩展技能: $file"
  for section in "角色定位" "核心原则" "决策框架" "反模式修复表" "好/坏示例" "验证证据"; do
    sgrep "^## $section" "$file" || fail "多产物方法论技能缺少章节 $section: $file"
  done
done
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查技能命名 ==\n'
while IFS= read -r file; do
  dir=$(basename "$(dirname "$file")")
  case "$dir" in
    define-*|design-*|build-*|verify-*|ship-*|maintain-*|reflect-*) ;;
    *) fail "命名违规: $dir" ;;
  esac
done < <(find skills -name 'SKILL.md' | sort)
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查技能核心章节 ==\n'
while IFS= read -r file; do
  # maintain-workflow-using-unified 是引导技能，使用非标准格式，跳过章节检查
  dir=$(basename "$(dirname "$file")")
  [ "$dir" = "maintain-workflow-using-unified" ] && continue
  sgrep '^## .*入口/出口' "$file" || fail "缺少入口/出口章节: $file"
  sgrep '^## .*常见说辞' "$file" || fail "缺少常见说辞章节: $file"
  sgrep '^## .*红旗' "$file" || fail "缺少红旗章节: $file"
  sgrep '^## .*验证清单' "$file" || fail "缺少验证清单章节: $file"
done < <(find skills -name 'SKILL.md' | sort)
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查 CLAUDE 指针文件 ==\n'
sgrep 'AGENTS\.md' CLAUDE.md || fail "CLAUDE.md 必须指向 AGENTS.md"
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查 Agent 定义结构 ==\n'
# 审查类 agent：必须有审查维度 + 输出格式 + Blocking/Important/Suggestion
for file in agents/review-*.md agents/plan-*.md agents/refine-*.md agents/ship-*.md; do
  [ -f "$file" ] || continue
  sgrep '^name: ' "$file" || fail "缺少 name frontmatter: $file"
  sgrep '^description: ' "$file" || fail "缺少 description frontmatter: $file"
  sgrep '^# ' "$file" || fail "缺少 H1 标题: $file"
  sgrep '审查维度|审计维度' "$file" || fail "缺少审查维度/审计维度章节: $file"
  sgrep '输出格式' "$file" || fail "缺少输出格式章节: $file"
  sgrep 'Blocking.*Important.*Suggestion' "$file" || fail "缺少 Blocking/Important/Suggestion 分级: $file"
done
# 工程类 agent：必须有职责 + 输出格式
for file in agents/requirements-*.md agents/task-*.md agents/software-*.md agents/data-*.md agents/api-*.md agents/content-*.md agents/visual-*.md; do
  [ -f "$file" ] || continue
  sgrep '^name: ' "$file" || fail "缺少 name frontmatter: $file"
  sgrep '^description: ' "$file" || fail "缺少 description frontmatter: $file"
  sgrep '^# ' "$file" || fail "缺少 H1 标题: $file"
  sgrep '职责' "$file" || fail "缺少职责章节: $file"
  sgrep '输出格式' "$file" || fail "缺少输出格式章节: $file"
done
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查过期内容 ==\n'
if sgrep_n '第 9 条（Every Feature Leaves a Trace|CANON\.md 9 条|9 条不可变|宪法的 9 条|Use AskUserQuestion, Never Plain Text|禁止.*纯文本' \
  CANON.md README.md CLAUDE.md AGENTS.md docs/directory-architecture.md skills >/tmp/unified-validate-stale-canon.$$ 2>/dev/null; then
  cat /tmp/unified-validate-stale-canon.$$
  rm -f /tmp/unified-validate-stale-canon.$$
  fail '发现过期宪法编号或不可移植提问规则'
else
  rm -f /tmp/unified-validate-stale-canon.$$
fi

if sgrep_n '30 技能|30 SKILL|30 个技能|35 技能|35 SKILL|43 技能|43 SKILL|44 技能|44 SKILL|46 技能|46 SKILL|47 技能|47 SKILL|11 命令|构建 \| 13|构建（13）|verify 验证 \| [79]|验证（[79]\）|ship 发布 \| [34]|发布（[34]\）|维护 \| 2|维护（2）|维护（5）|5 命令|10 命令' \
  README.md CLAUDE.md AGENTS.md docs/directory-architecture.md package.json .claude-plugin/plugin.json >/tmp/unified-validate-stale-count.$$ 2>/dev/null; then
  cat /tmp/unified-validate-stale-count.$$
  rm -f /tmp/unified-validate-stale-count.$$
  fail '发现过期技能数量说明'
else
  rm -f /tmp/unified-validate-stale-count.$$
fi

if sgrep_n '6 模板|templates/feature/review\.md|templates/feature/ship\.md' \
  README.md CLAUDE.md AGENTS.md docs/directory-architecture.md >/tmp/unified-validate-stale-template.$$ 2>/dev/null; then
  cat /tmp/unified-validate-stale-template.$$
  rm -f /tmp/unified-validate-stale-template.$$
  fail '发现过期模板说明'
else
  rm -f /tmp/unified-validate-stale-template.$$
fi

if sgrep_n 'fail-open|permissionDecision: "ask".*Codex|Codex.*permissionDecision: "ask"|docs/features/.*/ship\.md|docs/features/<name>/ship\.md|docs/features/YYYYMMDD-<name>/ship\.md|verify-quality-code-review-standards|scripts/install-codex\.sh|\.agents/skills/' \
  README.md CLAUDE.md AGENTS.md docs/directory-architecture.md skills >/tmp/unified-validate-stale-contract.$$ 2>/dev/null; then
  cat /tmp/unified-validate-stale-contract.$$
  rm -f /tmp/unified-validate-stale-contract.$$
  fail '发现过期合同说明'
else
  rm -f /tmp/unified-validate-stale-contract.$$
fi

if sgrep_n '\bcodex_hooks\b|\[features\]\.codex_hooks' \
  README.md CLAUDE.md AGENTS.md .codex/config.toml .codex/hooks.json .codex-plugin .claude-plugin docs commands agents skills templates references >/tmp/unified-validate-stale-codex-hooks.$$ 2>/dev/null; then
  cat /tmp/unified-validate-stale-codex-hooks.$$
  rm -f /tmp/unified-validate-stale-codex-hooks.$$
  fail '发现已废弃 Codex hooks feature flag'
else
  rm -f /tmp/unified-validate-stale-codex-hooks.$$
fi

if sgrep_n '写入 CLAUDE\.md|CLAUDE\.md/spec|CLAUDE\.md / spec|CLAUDE\.md / AGENTS\.md|调用 \.agents/skills/' \
  skills/build-cognitive-context/SKILL.md \
  skills/reflect-team-documentation/SKILL.md \
  skills/define-cognitive-brainstorm/SKILL.md \
  docs/architecture/command-agent-skill-architecture.md >/tmp/unified-validate-stale-entry.$$ 2>/dev/null; then
  cat /tmp/unified-validate-stale-entry.$$
  rm -f /tmp/unified-validate-stale-entry.$$
  fail '发现旧入口模型残留'
else
  rm -f /tmp/unified-validate-stale-entry.$$
fi
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查自动化脚本 ==\n'

# 检查版本同步脚本
if [ ! -f "scripts/sync-version.sh" ]; then
  fail "缺少版本同步脚本: scripts/sync-version.sh"
else
  [ -x "scripts/sync-version.sh" ] || fail "版本同步脚本不可执行: chmod +x scripts/sync-version.sh"
fi

# 检查索引生成脚本
