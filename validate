    extra = sorted(phase_refs - root_set)
    if missing:
        errors.append("by_phase 缺少: " + ", ".join(missing))
    if extra:
        errors.append("by_phase 多余: " + ", ".join(extra))
missing_ref_desc = sorted(all_refs - desc_refs)
if missing_ref_desc:
