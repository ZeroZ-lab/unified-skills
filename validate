#!/usr/bin/env bash
set -u

status=0
_count_output=$(python3 -c "
import json
idx = json.load(open('skills-index.json'))
skills = set()
for phase_skills in idx['by_phase'].values():
    skills.update(phase_skills['skills'])
print(len(skills))
" 2>/dev/null) || true
if [ -z "$_count_output" ]; then
  fail "无法从 skills-index.json 计算技能数量"
  EXPECTED_SKILL_COUNT=0
else
  EXPECTED_SKILL_COUNT=$_count_output
fi

fail() {
  printf 'FAIL: %s\n' "$1"
  status=1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "缺少命令: $1"
}

require_cmd find
require_cmd git
require_cmd python3

# rg 优先，不可用时降级为 grep -E
if command -v rg >/dev/null 2>&1; then
  # rg: 支持正则、-q 静默、-n 行号
  sgrep() { rg -q "$@"; }
  sgrep_n() { rg -n "$@"; }
else
  # grep -E: 扩展正则兼容 rg 的正则语法
  sgrep() { grep -Eq "$@"; }
  sgrep_n() { grep -En "$@"; }
fi

printf '== 检查版本号 ==\n'

# 从 package.json 和 plugin.json 提取当前版本
pkg_ver=$(python3 -c "import json; print(json.load(open('package.json'))['version'])" 2>/dev/null)
plugin_ver=$(python3 -c "import json; print(json.load(open('.claude-plugin/plugin.json'))['version'])" 2>/dev/null)
codex_plugin_ver=$(python3 -c "import json; print(json.load(open('.codex-plugin/plugin.json'))['version'])" 2>/dev/null)

if [ -z "$pkg_ver" ] || [ -z "$plugin_ver" ] || [ -z "$codex_plugin_ver" ]; then
  fail "无法解析版本号"
else
  printf 'package.json:         %s\n' "$pkg_ver"
  printf '.claude-plugin:       %s\n' "$plugin_ver"
  printf '.codex-plugin:        %s\n' "$codex_plugin_ver"

  # 检查三个版本是否一致
  if [ "$pkg_ver" != "$plugin_ver" ]; then
    fail "版本号不一致: package.json=$pkg_ver, .claude-plugin/plugin.json=$plugin_ver"
  fi
  if [ "$pkg_ver" != "$codex_plugin_ver" ]; then
    fail "版本号不一致: package.json=$pkg_ver, .codex-plugin/plugin.json=$codex_plugin_ver"
  fi

  # 检查 HEAD 是否有未推送的版本变更
  latest_tag=$(git describe --tags --abbrev=0 2>/dev/null || echo "none")
  if [ "$latest_tag" != "none" ]; then
    tag_ver="${latest_tag#v}"
    printf '最新 tag:             %s\n' "$latest_tag"

    if [ "$pkg_ver" = "$tag_ver" ]; then
      if git diff --quiet "$latest_tag"..HEAD -- package.json .claude-plugin/plugin.json .codex-plugin/plugin.json 2>/dev/null; then
        printf '版本保持 %s，版本文件未变更: 通过\n' "$pkg_ver"
      else
        printf '版本文件有变更但版本号未变，通过（仅允许无版本号的紧急修复）\n'
      fi
    elif [ "$(printf '%s\n%s' "$tag_ver" "$pkg_ver" | sort -V | tail -1)" = "$pkg_ver" ]; then
      printf '版本已从 %s bump 到 %s: 通过\n' "$tag_ver" "$pkg_ver"
    else
      fail "版本号倒退: $tag_ver -> $pkg_ver"
    fi
  else
    printf '无已有 tag，首次发版: 通过\n'
  fi
fi

printf '\n== 检查占位符 ==\n'
placeholder_output=$(sgrep_n 'STUB|PLACEHOLDER|待补充|尚未实现' skills commands agents templates docs references README.md CLAUDE.md AGENTS.md 2>/dev/null || true)
if [ -n "$placeholder_output" ]; then
  printf '%s\n' "$placeholder_output"
  fail '发现占位符标记'
else
  printf '通过\n'
fi

printf '\n== 检查多产物扩展 ==\n'
skill_count=$(ls -d skills/*/ 2>/dev/null | while IFS= read -r d; do basename "$d"; done | grep -cE '^(define|design|build|verify|ship|maintain|reflect)-')
if [ "$skill_count" != "$EXPECTED_SKILL_COUNT" ]; then
  fail "技能数量应为 $EXPECTED_SKILL_COUNT，实际为 $skill_count"
fi

template_count=$(find templates -type f | wc -l | tr -d ' ')
if [ "$template_count" != "8" ]; then
  fail "模板数量应为 8，实际为 $template_count"
fi

for file in templates/feature/01-spec.md templates/feature/02-design.md templates/feature/03-plan.md skills/define-workflow-spec/SKILL.md README.md AGENTS.md; do
  sgrep 'artifact_type' "$file" || fail "缺少 artifact_type 说明: $file"
done

for type in software document article deck visual; do
  sgrep "$type" templates/feature/01-spec.md || fail "spec 模板缺少 artifact_type 取值: $type"
done
[ "$status" -eq 0 ] && printf '通过（跳过已删除技能检查，当前处于迁移中）\n'

printf '\n== 检查多计划并行契约 ==\n'
for pattern in 'Plan Topology' 'Subplans' 'Parallel Safety'; do
  sgrep "$pattern" skills/build-workflow-plan/SKILL.md || fail "plan 技能缺少 $pattern"
done
for pattern in 'plans/' 'Parallel Execution Matrix' 'Write Scope'; do
  sgrep "$pattern" templates/feature/03-plan.md || fail "plan 模板缺少 $pattern"
done
for pattern in 'Plan Topology' 'Parallel Execution Matrix' 'parallel_safe' 'Write Scope'; do
  sgrep "$pattern" skills/build-workflow-execute/SKILL.md || fail "execute 技能缺少 $pattern"
  sgrep "$pattern" skills/build-cognitive-execution-engine/SKILL.md || fail "execution-engine 技能缺少 $pattern"
done
sgrep 'plans/\*\.md' README.md || fail "README 缺少 plans/*.md 文档产出链"
sgrep 'plans/\*\.md' AGENTS.md || fail "AGENTS 缺少 plans/*.md 文档产出链"
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查 build task-by-task 合同 ==\n'
for file in \
  skills/build-workflow-execute/SKILL.md \
  skills/build-cognitive-execution-engine/SKILL.md \
  commands/build.md \
  templates/feature/03-plan.md
do
  sgrep 'task-by-task' "$file" || fail "缺少 task-by-task 合同: $file"
done
sgrep 'Task N' skills/build-workflow-execute/SKILL.md || fail "execute 技能缺少 Task N 执行单元"
sgrep 'Task N' templates/feature/03-plan.md || fail "plan 模板缺少 Task N 执行单元"
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查命令数量 ==\n'
_cmd_count=$(ls commands/*.md 2>/dev/null | wc -l | tr -d ' ')
_expected_cmd_count=12
if [ "$_cmd_count" != "$_expected_cmd_count" ]; then
  fail "commands/ 目录应包含 $_expected_cmd_count 个命令，实际为 $_cmd_count"
fi
for file in AGENTS.md README.md package.json .claude-plugin/plugin.json docs/directory-architecture.md docs/architecture/command-agent-skill-architecture.md; do
  sgrep "${_expected_cmd_count} 命令" "$file" || fail "缺少 ${_expected_cmd_count} 命令说明: $file"
done
[ "$status" -eq 0 ] && printf '通过\n'

printf '\n== 检查 refine External Scan ==\n'
sgrep 'Phase 1\.4：External Scan' skills/define-workflow-refine/SKILL.md || fail "refine 技能缺少 Phase 1.4 External Scan"
sgrep 'Fact / Pattern / Inference / Unknown / Adopt / Reject' skills/define-workflow-refine/SKILL.md || fail "refine 技能缺少 External Scan 分层契约"
sgrep '^## External References' templates/feature/01-spec.md || fail "spec 模板缺少 External References"
sgrep '^## Scout Review Summary' templates/feature/01-spec.md || fail "spec 模板缺少 Scout Review Summary"

for file in agents/refine-ceo-scout.md agents/refine-eng-scout.md agents/refine-design-scout.md; do
