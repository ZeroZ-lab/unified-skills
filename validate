printf '\n== 检查 design evidence gate ==\n'
[ -f references/design-best-practices.md ] || fail "缺少设计最佳实践来源合同: references/design-best-practices.md"
for pattern in \
  'Enterprise Product Patterns' \
  'Official Systems / Platform Rules' \
  'Methods / Theory / Style Schools' \
  'Anti-patterns / Verification' \
  'Local Project Truth'
do
  sgrep "$pattern" references/design-best-practices.md || fail "design-best-practices 缺少来源层: $pattern"
done

