{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/codex-wrapper.sh session-start.sh",
            "statusMessage": "Loading Unified Skills"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/codex-wrapper.sh careful.sh",
            "statusMessage": "Checking for destructive commands"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/codex-wrapper.sh freeze.sh",
            "statusMessage": "Checking freeze boundary"
          }
        ]
      }
    ]
  }
}