  "by_artifact_type": {
    "software": {
      "required": ["build-quality-tdd", "build-infrastructure-git"],
      "frontend": ["build-frontend-ui-engineering", "build-frontend-browser-testing", "verify-frontend-accessibility"],
      "backend": ["build-backend-api-design", "build-backend-database", "build-backend-service-patterns"],
      "quality": ["verify-quality-security", "verify-quality-performance", "verify-quality-simplify"]
    },
    "document": {
      "required": ["build-content-writing"],
      "optional": ["build-content-layout"]
    },
    "article": {
      "required": ["build-content-writing", "verify-content-review"]
    },
    "deck": {
      "required": ["build-content-writing", "build-content-layout"],
      "sequence": ["build-content-writing", "build-content-layout"],
      "note": "必须先 writing 再 layout，不可并行"
    },
    "visual": {
      "required": ["build-content-layout", "verify-visual-review"]
    }
  },
  "by_trigger": {
    "user_says": {
      "bug|error|crash|报错|不工作|失败": ["verify-workflow-debug"],
      "test|测试|tdd|单元测试": ["build-quality-tdd"],
      "api|endpoint|接口|REST|GraphQL": ["build-backend-api-design"],
      "ui|前端|component|组件|页面": ["build-frontend-ui-engineering"],
      "performance|性能|慢|优化|latency": ["verify-quality-performance"],
      "security|安全|漏洞|攻击|XSS|SQL注入": ["verify-quality-security"],
      "database|数据库|schema|migration|查询": ["build-backend-database"],
      "accessibility|无障碍|a11y|WCAG": ["verify-frontend-accessibility"],
      "review|审查|code review": ["verify-workflow-review"],
      "deploy|部署|上线|发布": ["ship-workflow-ship"],
      "brainstorm|头脑风暴|想法|方案": ["define-cognitive-brainstorm"],
      "refine|提炼|收敛|spec": ["define-workflow-refine"],
      "plan|计划|任务|拆分": ["build-workflow-plan"],
      "document|文档|article|文章": ["build-content-writing"],
      "deck|PPT|演示|slides": ["build-content-writing", "build-content-layout"],
      "git|版本控制|commit|branch": ["build-infrastructure-git"],
      "ci|cd|pipeline|持续集成": ["ship-infrastructure-ci-cd"],
      "observability|监控|日志|metrics": ["maintain-infrastructure-observability"],
      "retro|回顾|复盘|postmortem": ["reflect-team-retro"]
    },
    "context_signals": {
      "has_spec_no_plan": ["build-workflow-plan"],
      "has_plan_no_code": ["build-workflow-execute"],
      "has_code_no_tests": ["build-quality-tdd"],
      "has_code_no_review": ["verify-workflow-review"],
      "has_review_no_ship": ["ship-workflow-ship"],
      "new_session_has_checkpoint": ["maintain-workflow-context-restore"],
      "complex_codebase_unfamiliar": ["build-cognitive-context"],
      "using_unfamiliar_api": ["build-cognitive-source-driven"],
      "facing_technical_decision": ["build-cognitive-decision-record"]
    }
  },
  "by_risk": {
    "user_input": ["verify-quality-security"],
    "authentication": ["verify-quality-security"],
    "authorization": ["verify-quality-security"],
    "data_storage": ["verify-quality-security", "build-backend-database"],
    "ui_change": ["verify-frontend-accessibility"],
    "performance_critical": ["verify-quality-performance"],
    "public_api": ["build-backend-api-design", "verify-quality-security"],
    "breaking_change": ["verify-quality-integration-testing"],
    "production_deployment": ["ship-workflow-ship", "ship-workflow-canary"]
  },
